{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": "Data Factory name",
            "defaultValue": "adf-for-basicprojects"
        },
        "LS_ONPREM_SQL_TO_BLOB_PARQ_password": {
            "type": "secureString",
            "metadata": "Secure string for 'password' of 'LS_ONPREM_SQL_TO_BLOB_PARQ'"
        },
        "LS_FOR_AZ_BLOB_connectionString": {
            "type": "secureString",
            "metadata": "Secure string for 'connectionString' of 'LS_FOR_AZ_BLOB'"
        },
        "LS_FOR_AZ_BLOB_EXCEL_connectionString": {
            "type": "secureString",
            "metadata": "Secure string for 'connectionString' of 'LS_FOR_AZ_BLOB_EXCEL'"
        },
        "LS_ONPREM_SQL_TO_BLOB_PARQ_properties_typeProperties_server": {
            "type": "string",
            "defaultValue": "LAPTOP-1RR2JTHG"
        },
        "LS_ONPREM_SQL_TO_BLOB_PARQ_properties_typeProperties_database": {
            "type": "string",
            "defaultValue": "AdventureWorksLT2025"
        },
        "LS_ONPREM_SQL_TO_BLOB_PARQ_properties_typeProperties_userName": {
            "type": "string",
            "defaultValue": "admindata01"
        },
        "containerUri": {
            "type": "string",
            "metadata": "URI to storage account containing linked ARM templates"
        },
        "containerSasToken": {
            "type": "string",
            "metadata": "Sas token to storage account containing linked ARM templates"
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "adf-for-basicprojects_ArmTemplate_0",
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2024-03-01",
            "properties": {
                "mode": "incremental",
                "templateLink": {
                    "uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "factoryName": {
                        "value": "[parameters('factoryName')]"
                    },
                    "LS_FOR_AZ_BLOB_connectionString": {
                        "value": "[parameters('LS_FOR_AZ_BLOB_connectionString')]"
                    },
                    "LS_FOR_AZ_BLOB_EXCEL_connectionString": {
                        "value": "[parameters('LS_FOR_AZ_BLOB_EXCEL_connectionString')]"
                    },
                    "LS_ONPREM_SQL_TO_BLOB_PARQ_password": {
                        "value": "[parameters('LS_ONPREM_SQL_TO_BLOB_PARQ_password')]"
                    },
                    "LS_ONPREM_SQL_TO_BLOB_PARQ_properties_typeProperties_server": {
                        "value": "[parameters('LS_ONPREM_SQL_TO_BLOB_PARQ_properties_typeProperties_server')]"
                    },
                    "LS_ONPREM_SQL_TO_BLOB_PARQ_properties_typeProperties_database": {
                        "value": "[parameters('LS_ONPREM_SQL_TO_BLOB_PARQ_properties_typeProperties_database')]"
                    },
                    "LS_ONPREM_SQL_TO_BLOB_PARQ_properties_typeProperties_userName": {
                        "value": "[parameters('LS_ONPREM_SQL_TO_BLOB_PARQ_properties_typeProperties_userName')]"
                    }
                }
            },
            "dependsOn": []
        }
    ]
}